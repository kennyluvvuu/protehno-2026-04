# ------------------------------------------------------------------------------
# Docker Compose project settings
# ------------------------------------------------------------------------------

# Optional compose project name used in container/volume naming.
COMPOSE_PROJECT_NAME=jwtusers

# ------------------------------------------------------------------------------
# Caddy (local default)
# ------------------------------------------------------------------------------

# Host port to expose HTTP endpoint of Caddy.
CADDY_HTTP_PORT=80

# Caddy config path used by compose. Keep ./Caddyfile for local HTTP workflow.
CADDYFILE_PATH=./Caddyfile

# HTTPS host port used in production override file.
CADDY_HTTPS_PORT=443

# ------------------------------------------------------------------------------
# Caddy domains (production / SSL)
# ------------------------------------------------------------------------------

# Domain for API traffic.
CADDY_API_DOMAIN=api.example.com

# Domain for manager UI.
CADDY_MANAGER_DOMAIN=manager.example.com

# Domain for director UI.
CADDY_DIRECTOR_DOMAIN=director.example.com

# Optional landing page domain.
CADDY_LANDING_DOMAIN=example.com

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------

# Database name that will be created inside the PostgreSQL container.
POSTGRES_DB=jwtusers

# Database user for the application connection.
POSTGRES_USER=jwtusers

# Database password for the application connection.
POSTGRES_PASSWORD=change_me_postgres_password

# Host port to expose PostgreSQL on your machine.
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Backend
# ------------------------------------------------------------------------------

# JWT secret used to sign auth cookies/tokens.
JWT_SECRET=change_me_super_secret_jwt_key

# Service key for protected backend routes via x-api-key header.
SERVICE_API_KEY=change_me_service_api_key

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------

# Base URL used by the frontend containers to call the backend container.
# Inside Docker network it should point to the backend service name.
FRONTEND_MANAGER_VITE_BASE_URL=http://backend:3000
FRONTEND_DIRECTOR_VITE_BASE_URL=http://backend:3000

# Axios timeout for frontend requests in milliseconds.
VITE_TIMEOUT=10000

# ------------------------------------------------------------------------------
# AI / external providers
# ------------------------------------------------------------------------------

# Groq API key for audio transcription.
GROQ_API_KEY=your_groq_api_key

# Groq-compatible base URL for transcription API.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Transcription model name.
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Mistral API key for summaries and other LLM tasks.
MISTRAL_API_KEY=your_mistral_api_key

# Mistral model used for summaries.
MISTRAL_SUMMARY_MODEL=mistral-small-latest

# ------------------------------------------------------------------------------
# Mango Office integration
# ------------------------------------------------------------------------------

# Mango Office VPBX API key.
MANGO_VPBX_API_KEY=

# Mango Office VPBX API salt.
MANGO_VPBX_API_SALT=

# Base URL for Mango Office API.
MANGO_BASE_URL=https://app.mango-office.ru

# ------------------------------------------------------------------------------
# Optional backend startup tuning
# ------------------------------------------------------------------------------

# How many times the backend container should retry waiting for PostgreSQL.
DB_WAIT_MAX_ATTEMPTS=30
