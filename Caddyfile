{
	auto_https off
}

http://api.localhost {
	reverse_proxy backend:3000
}

http://manager.localhost {
	handle_path /api/* {
		reverse_proxy backend:3000
	}

	handle {
		reverse_proxy frontend-manager:3000
	}
}

http://director.localhost {
	handle_path /api/* {
		reverse_proxy backend:3000
	}

	handle {
		reverse_proxy frontend-director:3000
	}
}

